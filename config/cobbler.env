# ============================================================================
# cobbler.env — configuration for the offline Cobbler (Ubuntu) provisioning kit.
# Edit these, then the numbered scripts read them automatically.
# ============================================================================

# ---- Cobbler server (the offline Ubuntu box that runs Cobbler) -------------
# You said your offline network already has DHCP + DNS, so Cobbler does NOT
# manage DHCP/DNS; it only serves TFTP + HTTP. Point your existing DHCP at this IP.
COBBLER_SERVER_IP="192.168.108.93"

# ---- Target Ubuntu releases to provision -----------------------------------
# Ubuntu 22.04.1 — DESKTOP edition.
# NOTE: autoinstall on DESKTOP differs from server:
#   * 22.04.x Desktop uses the OLD ubiquity installer, which does NOT support
#     autoinstall — for hands-off 22.04, server is the reliable choice. See README.

# ---- Ubuntu 22.04.1 Desktop ISO configuration ------------------------------
# URL pointing directly to the archived 22.04.1 point release Desktop ISO
UBUNTU_2204_ISO_URL="https://old-releases.ubuntu.com/releases/22.04.1/ubuntu-22.04.1-desktop-amd64.iso"

# The name/label your environment uses to identify this ISO file internally
UBUNTU_2204_LABEL="ubuntu-22.04.1-desktop-amd64"

# The distro codename (used for the local repo / package gathering).
UBUNTU_2204_CODENAME="jammy"

# ---- Noble bypass slot (forced to point to 22.04.1 to skip download errors) ----
UBUNTU_NOBLE_CODENAME="jammy"
UBUNTU_NOBLE_LABEL="ubuntu-22.04.1-desktop-amd64"
UBUNTU_NOBLE_ISO_URL="https://old-releases.ubuntu.com/releases/22.04.1/ubuntu-22.04.1-desktop-amd64.iso"

# Only gather local debs for jammy to save time and space
TARGET_CODENAMES="jammy"

# ---- Post-install packages installed on EACH deployed machine (offline) ----
# Covers the pituah post-install: usbguard, FreeIPA/Kerberos, SSH, NFS/CIFS, chrony.
POSTINSTALL_PACKAGES="usbguard freeipa-client krb5-user sssd oddjob-mkhomedir \
  openssh-server nfs-common cifs-utils chrony dos2unix ca-certificates"

# ---- Where deployed machines get their .deb packages -----------------------
#   "archive"   = use your EXISTING offline apt mirror (ARCHIVE_APT_LINES below).
#                 Skips debootstrap in step 1 and the local .deb repo entirely.
#   "localdebs" = use the per-release .deb repo this kit builds via debootstrap
#                 and serves from Cobbler over HTTP.
PKG_SOURCE="archive"

# apt sources for your offline archive mirror (used when PKG_SOURCE="archive").
# {RELEASE} is replaced with the codename (jammy / noble). Add/adjust as needed.
ARCHIVE_APT_LINES="deb http://192.168.108.51/ubuntu {RELEASE} main restricted universe multiverse
deb http://192.168.108.51/ubuntu {RELEASE}-updates main restricted universe multiverse"

# ---- Cobbler SERVER dependencies -------------------------------------------
# The Cobbler application itself (pip: cobbler + mod_wsgi + python-ldap) is NOT
# in any Ubuntu mirror, so the pip WHEELHOUSE is ALWAYS bundled. Only the SYSTEM
# dependency .debs below can optionally come from your archive mirror instead.
#   "archive" = the offline Cobbler server installs these via apt from your mirror
#               (its apt must already point at your mirror). Skips bundling debs.
#   "bundle"  = download the .debs now and install them offline from the bundle.
COBBLER_DEPS_SOURCE="archive"

# System packages Cobbler needs on the offline Ubuntu server.
COBBLER_SYS_DEPS="apache2 apache2-dev libapache2-mod-wsgi-py3 tftpd-hpa rsync xorriso \
  createrepo-c dosfstools mtools syslinux syslinux-common pxelinux grub-common \
  grub-pc-bin grub-efi-amd64-bin python3 python3-pip python3-dev python3-cheetah \
  python3-dnspython python3-netaddr python3-requests python3-distro python3-schema \
  python3-yaml python3-gunicorn python3-magic build-essential libldap2-dev libsasl2-dev \
  libsystemd-dev pkg-config"

# ---- FreeIPA (domain join) -------------------------------------------------
IPA_DOMAIN="example.com"
IPA_REALM="EXAMPLE.COM"
IPA_SERVER="ipa.example.com"
# Enrollment principal (pituah uses 'admin'). Its password is PROMPTED during
# offline install and stored root-only in config/ipa_join.secret (injected into
# the rendered post-install script). See the security note in the README.
IPA_PRINCIPAL="admin"

# ---- Site network settings (used by the pituah post-install job) -----------
SECONDARY_DNS="192.168.108.1"
NTP_SERVER="192.168.108.1"
TIMEZONE="Asia/Jerusalem"

# ---- Optional CIFS share mount (set ENABLE_CIFS=0 to skip) -----------------
ENABLE_CIFS="1"
CIFS_UNC="//192.168.108.70/Support$"
CIFS_MOUNTPOINT="/mnt/network-drives/Support"
CIFS_USER="svc_cifs"
# CIFS password is prompted at install (root-only config/cifs.secret) if ENABLE_CIFS=1.

# ---- Optional Trellix AV smart-install (set ENABLE_TRELLIX=0 to skip) -------
ENABLE_TRELLIX="1"
TRELLIX_SCRIPT="/mnt/network-drives/Support/FramePkg/SmaretInstallLinux/TrellixSmartInstall.sh"

# ---- CA certificates to trust (fetched from Cobbler at first boot) ---------
# Put these files in cobbler/certs/ before running 1-download-offline-bundle.sh.
CA_CERTS="root_2024_ca.crt intermediate_2024_ca.crt"

# ---- Ansible user (for deploying playbooks over SSH later) -----------------
ANSIBLE_USER="ansible"
# The public key is generated during offline install (2-install-offline.sh) and
# written to config/ansible_id_ed25519.pub; 3-configure-cobbler.sh injects it.

# ---- Local admin user (break-glass, root/sudo, works with no network) ------
LOCALADMIN_USER="localadmin"
# The password is PROMPTED during offline install and stored ONLY as a
# SHA-512 crypt hash in config/localadmin.hash (never plaintext, never in git).