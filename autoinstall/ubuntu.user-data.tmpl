#cloud-config
# ubuntu.user-data.tmpl — Ubuntu autoinstall (subiquity) TEMPLATE.
#
# 3-configure-cobbler.sh renders this into a per-release file by replacing the
# __PLACEHOLDERS__ from cobbler.env + install-time values. new-host.sh then
# stamps per-machine values (hostname + FreeIPA OTP).
#
# What each deployed machine gets:
#   * usbguard installed with rules that allow ONLY keyboards + mice (HID) and hubs
#   * enrolled into the FreeIPA domain
#   * an 'ansible' user with SSH-key login + passwordless sudo (for playbooks)
#   * a local admin user with sudo/root (break-glass, password prompted at install)
#
# Offline notes:
#   * apt.fallback=offline-install makes subiquity use the ISO's package pool
#     when no internet mirror is reachable (so the base install works air-gapped).
#   * usbguard + freeipa-client come from the LOCAL apt repo served by Cobbler
#     (installed in late-commands), because they're not on the live-server ISO.

autoinstall:
  version: 1

  locale: en_US.UTF-8
  keyboard:
    layout: us

  network:
    version: 2
    ethernets:
      any:
        match:
          name: "e*"
        dhcp4: true

  # Air-gapped: fall back to the ISO pool instead of hanging on a network mirror.
  apt:
    fallback: offline-install
    geoip: false

  # Local admin (primary user). Password is a SHA-512 crypt hash injected at install.
  identity:
    hostname: __HOSTNAME__
    username: __LOCALADMIN_USER__
    password: "__LOCALADMIN_HASH__"

  ssh:
    install-server: true
    allow-pw: false

  # Extra packages are installed from the local repo in late-commands (offline),
  # so we intentionally do NOT list them here (avoids a network apt fetch).

  late-commands:
    # ---------------------------------------------------------------
    # 1) Configure the package source (archive mirror OR bundled local repo,
    #    decided at configure time) and pre-install the post-install packages
    #    so first boot has them ready. Both sources are reachable over the LAN.
    # ---------------------------------------------------------------
    - "curl -fsSL http://__COBBLER_SERVER_IP__/pituah/__RELEASE__/provision-sources.list -o /target/etc/apt/sources.list.d/provision.list"
    - curtin in-target -- apt-get -o Acquire::Languages=none update
    - curtin in-target -- env DEBIAN_FRONTEND=noninteractive apt-get install -y usbguard freeipa-client krb5-user sssd oddjob-mkhomedir openssh-server nfs-common cifs-utils chrony dos2unix

    # ---------------------------------------------------------------
    # 2) Drop the pituah post-install job + register a RUN-ONCE service that
    #    executes it on FIRST BOOT (full network up), then disables itself.
    #    The job does: hostname-from-serial, CA certs, NTP, FreeIPA join,
    #    ansible user, CIFS mount, Trellix, and usbguard (kbd/mouse only).
    # ---------------------------------------------------------------
    - "curl -fsSL http://__COBBLER_SERVER_IP__/pituah/__RELEASE__/pituah-postinstall.sh -o /target/usr/local/sbin/pituah-postinstall.sh"
    - "chmod 0750 /target/usr/local/sbin/pituah-postinstall.sh"
    - |
      cat > /target/etc/systemd/system/pituah-postinstall.service <<'UNIT'
      [Unit]
      Description=Pituah first-boot post-install (domain join, usbguard, users)
      After=network-online.target
      Wants=network-online.target
      ConditionPathExists=/usr/local/sbin/pituah-postinstall.sh

      [Service]
      Type=oneshot
      ExecStart=/usr/local/sbin/pituah-postinstall.sh
      RemainAfterExit=no

      [Install]
      WantedBy=multi-user.target
      UNIT
    - curtin in-target -- systemctl enable pituah-postinstall.service

  shutdown: reboot
